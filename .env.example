PORT=8090
NODE_ENV=development

# Comma separated origins for browser clients
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:19006


# AWS and SQS
AWS_REGION=us-west-2
SQS_QUEUE_NAME=platform-notifications-queue
# Optional: use full queue URL to bypass GetQueueUrl lookup
# SQS_QUEUE_URL=https://sqs.us-west-2.amazonaws.com/123456789012/platform-notifications-queue
SQS_WAIT_TIME_SECONDS=20
SQS_MAX_MESSAGES=10
SQS_VISIBILITY_TIMEOUT_SECONDS=30

# Socket
SOCKET_PATH=/socket.io
SOCKET_EVENT_NAME=notification
CLIENT_SUBSCRIBE_EVENT=subscribe
CLIENT_UNSUBSCRIBE_EVENT=unsubscribe

# Optional Redis adapter for multi-instance socket fanout
# REDIS_URL=redis://localhost:6379
