{
  "name": "platform-socket-gateway",
  "version": "1.0.0",
  "private": true,
  "description": "Stateless Socket.IO gateway that consumes SQS notifications and pushes realtime updates to clients",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@aws-sdk/client-sqs": "^3.868.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "redis": "^4.7.0",
    "socket.io": "^4.8.0",
    "@socket.io/redis-adapter": "^8.3.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.7.4",
    "tsx": "^4.19.2",
    "typescript": "^5.6.2"
  },
  "engines": {
    "node": ">=20"
  }
}
